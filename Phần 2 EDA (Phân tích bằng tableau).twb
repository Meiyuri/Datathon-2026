      <aliases enabled='yes' />
      <column caption='Estimated Revenue' datatype='real' name='[Calculation_1625693209661440]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([units_sold] * [price]) - ZN(SUM([discount_amount]))' />
      </column>
      <column caption='Cảnh Báo Đọng Vốn' datatype='string' name='[Calculation_1625693215821827]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF AVG([days_of_supply]) &gt; 365 THEN &quot;Báo Động Đỏ (&gt; 365 ngày)&quot;&#13;&#10;ELSE &quot;An Toàn&quot;&#13;&#10;END' />
      </column>
      <column caption='Gross Cash In - Doanh thu Gộp' datatype='real' name='[Calculation_1625693223301124]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([quantity] * [unit_price]) - SUM([discount_amount])' />
      </column>
      <column caption='Net Cash In - Doanh thu Thuần' datatype='real' name='[Calculation_1625693223424005]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_1625693223301124] - SUM(ZN([refund_amount]))' />
      </column>
      <column caption='Tỷ trọng Doanh thu' datatype='real' name='[Calculation_1625693224058886]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Revenue]) / TOTAL(SUM([Revenue]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Cash Out - Dòng tiền ra' datatype='real' default-format='c#,##0&quot; VNĐ&quot;' name='[Calculation_2505577177546752]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([units_received] * [cogs])' />
      </column>
      <column caption='Tiền giảm giá' datatype='real' default-format='c#,##0&quot;VNĐ&quot;' name='[Calculation_2505577178390529]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [promo_type] = &apos;percentage&apos; THEN&#13;&#10;    [quantity] * [unit_price] * ([discount_value] / 100)&#13;&#10;ELSEIF [promo_type] = &apos;fixed&apos; THEN&#13;&#10;    [quantity] * [discount_value]&#13;&#10;ELSE&#13;&#10;    0&#13;&#10;END' />
      </column>
      <column caption='Dead Capital - Vốn đọng tồn kho' datatype='real' default-format='c#,##0&quot;VNĐ&quot;' name='[Calculation_2505577187000324]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([stock_on_hand] * [cogs])' />
      </column>
      <column caption='Tỷ lệ hoàn hàng' datatype='real' default-format='c#,##0&quot; VNĐ&quot;' name='[Calculation_2505577202176005]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_quantity]) / SUM([quantity])' />
      </column>
      <column caption='Tổng tiền bán SP' datatype='real' name='[Calculation_2505577211699207]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([quantity] * [unit_price]) - SUM([discount_amount])) &#13;&#10;- &#13;&#10;ZN(LOOKUP(SUM([refund_amount]), 0))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
